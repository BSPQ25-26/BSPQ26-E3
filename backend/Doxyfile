# Doxyfile for Plants REST API

PROJECT_NAME           = "Plants REST API"
PROJECT_NUMBER         = "1.0"
PROJECT_BRIEF          = "Spring Boot backend documentation generated for Sprint 3."
OUTPUT_DIRECTORY       = target/doxygen
INPUT                  = src/main/java
FILE_PATTERNS          = *.java
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# Language
OPTIMIZE_OUTPUT_JAVA   = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_TIMESTAMP         = YES

# LaTeX / PDF output
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
LATEX_BATCHMODE        = YES

# Graphs (requires graphviz)
HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = YES
UML_LOOK               = YES

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
